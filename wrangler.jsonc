{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cf-redis-kv-worker",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-03",
  "kv_namespaces": [
    {
      "binding": "REDIS_KV",
      "id": "replace-with-production-kv-id",
      "preview_id": "replace-with-preview-kv-id"
    }
  ],
  "vars": {
    "ALLOW_UNAUTHENTICATED": "false"
  }
}
